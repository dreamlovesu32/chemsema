# Keep repo-authored source and documentation files on LF across platforms.
/.gitattributes text eol=lf
*.md text eol=lf
*.rs text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.svg text eol=lf

# Keep Windows-native scripts in CRLF form for local execution ergonomics.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
