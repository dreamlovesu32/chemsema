# Keep repo-authored source and documentation files on LF across platforms.
/.gitattributes text eol=lf
/CODE_OF_CONDUCT.md text eol=lf
/CONTRIBUTING.md text eol=lf
/LICENSE text eol=lf
/NOTICE text eol=lf
/SECURITY.md text eol=lf
*.md text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.json text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.nsh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.svg text eol=lf

# Preserve ChemDraw source files exactly as exported.
*.cdxml binary

# Preserve the vendored official IUPAC InChI source byte-for-byte. Upstream
# source intentionally contains whitespace that does not follow this repo's
# authored-source style checks.
/third_party/inchi-1.07.5/** -text -whitespace

# Keep Windows-native scripts in CRLF form for local execution ergonomics.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
