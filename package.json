{
  "name": "chemsema",
  "version": "1.0.0-beta.1",
  "description": "An open-source chemistry structure editor focused on CDXML fidelity and Office workflows.",
  "homepage": "https://dreamlovesu32.github.io/chemsema/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dreamlovesu32/chemsema.git"
  },
  "type": "module",
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "example": "examples"
  },
  "scripts": {
    "build:engine-wasm": "node scripts/build-engine-wasm.mjs",
    "cli:ubuntu:build": "node scripts/wsl-cli.mjs build",
    "cli:ubuntu:smoke": "node scripts/wsl-cli.mjs smoke",
    "cli:ubuntu:test": "node scripts/wsl-cli.mjs test",
    "cli:linux:package": "node scripts/package-linux-cli.mjs",
    "cli": "cargo run -p chemsema-cli --",
    "compare:cdxml-symbol-pixels": "node scripts/compare-cdxml-symbol-pixels.mjs",
    "compare:svg-pixels": "node scripts/compare-svg-pixels.mjs",
    "desktop:build": "node scripts/desktop-tauri.mjs build",
    "desktop:build-fast": "node scripts/desktop-tauri-fast.mjs",
    "desktop:dev-fast": "node scripts/desktop-tauri-dev-fast.mjs",
    "desktop:dev": "node scripts/desktop-tauri.mjs dev",
    "desktop:info": "node scripts/desktop-tauri.mjs info",
    "dev:engine": "node scripts/dev-engine-wasm.mjs",
    "dev:viewer": "node scripts/dev-viewer.mjs",
    "harmony:build": "node scripts/build-harmony.mjs",
    "harmony:bridge-regression": "node scripts/harmony-bridge-regression.mjs",
    "harmony:smoke": "node scripts/harmony-smoke.mjs",
    "harmony:sync-viewer": "node scripts/sync-harmony-viewer.mjs",
    "emf:chemdraw-oracle": "node scripts/chemdraw-oracle.mjs",
    "emf:compare-oracle": "node scripts/compare-emf-oracle.mjs",
    "probe:chemdraw-arrows": "node scripts/chemdraw-arrow-probe.mjs",
    "probe:chemdraw-cdxml-fields": "node scripts/chemdraw-cdxml-field-probe.mjs",
    "emf:inspect": "node scripts/emf-inspect.mjs",
    "emf:render-preview": "node scripts/render-emf-preview.mjs",
    "examples:agent": "powershell -ExecutionPolicy Bypass -File examples/agent/run-all.ps1",
    "poc:agent": "powershell -ExecutionPolicy Bypass -File examples/agent/06-reaction-poc/run.ps1",
    "office:print-registration": "cargo run -p chemsema-office -- --print-registration",
    "office:register-dev": "cargo run -p chemsema-office -- --register-user",
    "office:serve": "cargo run -p chemsema-office -- --serve",
    "office:self-test": "cargo run -p chemsema-office -- --self-test",
    "office:validate-clipboard": "powershell -ExecutionPolicy Bypass -File scripts/validate-word-clipboard-paste.ps1",
    "office:unregister-dev": "cargo run -p chemsema-office -- --unregister-user",
    "office:validate-roundtrip": "powershell -ExecutionPolicy Bypass -File scripts/validate-word-ole-roundtrip.ps1",
    "performance:cli-large": "node scripts/cli-large-performance-report.mjs",
    "benchmark:cdxml-public:fetch": "node scripts/fetch-public-cdxml-corpus.mjs",
    "benchmark:cdxml-public": "node scripts/public-cdxml-roundtrip.mjs",
    "benchmark:cdxml-public:visual-gate": "node scripts/public-cdxml-visual-gate.mjs",
    "benchmark:cdxml-public:visual-gate:report": "node scripts/public-cdxml-visual-gate.mjs --report-only",
    "benchmark:cdxml-public:visual-gate:affected": "node scripts/plan-public-cdxml-affected-gate.mjs",
    "benchmark:cdxml-public:visual-gate:affected:test": "node --test scripts/tests/public-cdxml-impact.test.mjs",
    "regression:label-anchor": "node scripts/label-anchor-regression.mjs",
    "probe:label-retreat": "node scripts/chemdraw-label-retreat-probe.mjs",
    "probe:label-retreat:analyze": "node scripts/analyze-chemdraw-label-retreat.mjs",
    "regression:large-object-operations": "node scripts/large-object-operation-regression.mjs",
    "regression:large-cdxml-speed": "node scripts/large-cdxml-speed-regression.mjs",
    "regression:large-drag-preview": "node scripts/large-drag-preview-regression.mjs",
    "regression:desktop-hybrid-latency": "node scripts/desktop-hybrid-latency-regression.mjs",
    "regression:gui": "node scripts/gui-regression.mjs",
    "regression:shell-isolation": "node scripts/shell-isolation-regression.mjs",
    "regression:stability-user-paths": "node scripts/stability-user-paths.mjs",
    "regression:text-editor": "node scripts/text-editor-regression.mjs",
    "regression:toolbar": "node scripts/toolbar-regression.mjs",
    "regression:viewer-interactions": "node scripts/viewer-interaction-smoke.mjs",
    "check:legacy-redirects": "node scripts/check-legacy-redirects.mjs",
    "check:retired-name": "node scripts/check-retired-name.mjs",
    "check:cdx-cdxml-field-ledger": "node scripts/check-cdx-cdxml-field-ledger.mjs",
    "sync:cdx-cdxml-official-schema": "node scripts/sync-cdx-cdxml-official-schema.mjs",
    "generate:cdx-cdxml-field-ledger": "node scripts/generate-cdx-cdxml-verification-ledger.mjs",
    "generate:chemdraw-field-evidence": "node scripts/generate-chemdraw-field-evidence.mjs",
    "audit:cdx-cdxml-schema": "node scripts/audit-cdx-cdxml-schema-coverage.mjs",
    "stability": "node scripts/stability-report.mjs",
    "stability:fixtures": "node scripts/generate-stability-fixtures.mjs",
    "verify": "node scripts/verify.mjs",
    "readme:comparison": "node scripts/regenerate-readme-comparison.mjs",
    "screenshot": "node scripts/viewer-screenshot.mjs",
    "screenshot:svg": "node scripts/viewer-svg-screenshot.mjs",
    "skill:sync-cli-runtimes": "node scripts/sync-cli-skill-runtimes.mjs",
    "verify:kernel-surfaces": "node scripts/verify-kernel-surfaces.mjs",
    "test": "node scripts/test.mjs"
  },
  "keywords": [
    "chemistry",
    "cheminformatics",
    "cdxml",
    "chemdraw",
    "scientific-software",
    "svg",
    "wasm",
    "rust",
    "tauri",
    "office"
  ],
  "author": "Jiajun Zhang",
  "license": "Apache-2.0",
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.0",
    "opentype.js": "^2.0.0",
    "playwright": "^1.59.1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0"
  }
}
