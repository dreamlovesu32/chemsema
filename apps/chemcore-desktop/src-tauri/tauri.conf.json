{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Chemcore",
  "version": "0.1.0",
  "identifier": "com.chemcore.desktop",
  "build": {
    "frontendDist": "../../../viewer",
    "devUrl": "http://127.0.0.1:8767/viewer/",
    "beforeDevCommand": "node ../../scripts/desktop-dev-server.mjs",
    "beforeBuildCommand": "node ../../scripts/build-engine-wasm.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Chemcore",
        "width": 1280,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "shadow": true,
        "dragDropEnabled": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../../target/release/chemcore-office.exe": "chemcore-office.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["ccjz"],
        "name": "Chemcore Compressed Document",
        "description": "Chemcore compressed document",
        "role": "Editor",
        "mimeType": "application/vnd.chemcore+gzip"
      },
      {
        "ext": ["ccjs"],
        "name": "Chemcore JSON Document",
        "description": "Chemcore readable JSON document",
        "role": "Editor",
        "mimeType": "application/vnd.chemcore+json"
      },
      {
        "ext": ["cdxml"],
        "name": "ChemDraw CDXML Document",
        "description": "ChemDraw CDXML document",
        "role": "Editor",
        "mimeType": "chemical/x-cdxml"
      },
      {
        "ext": ["cdx"],
        "name": "ChemDraw CDX Document",
        "description": "ChemDraw CDX document",
        "role": "Editor",
        "mimeType": "chemical/x-cdx"
      },
      {
        "ext": ["sdf", "sd"],
        "name": "MDL SDfile",
        "description": "MDL structure-data file",
        "role": "Editor",
        "mimeType": "chemical/x-mdl-sdfile"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": true
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
