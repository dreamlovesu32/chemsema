{
  "schema": "chemsema.public_cdxml.visual_impact_map.v1",
  "rules": [
    {
      "name": "cdx-text-layout-import",
      "pathEquals": ["crates/chemsema-engine/src/cdx.rs"],
      "formats": ["cdx"],
      "features": ["text"],
      "regressionCases": ["0129", "0130", "0131"]
    },
    {
      "name": "cdxml-bond-import",
      "pathEquals": ["crates/chemsema-engine/src/cdxml.rs"],
      "formats": ["cdxml"],
      "features": ["bond", "dashed-bond"],
      "regressionCases": ["0016", "0017", "0018", "0019", "0020", "0021", "0023", "0025", "0026", "0028", "0029", "0204", "0205", "0212", "0220", "0295"]
    },
    {
      "name": "cdxml-object-tags",
      "pathSubstrings": [
        "crates/chemsema-engine/src/cdxml/import_objects.rs"
      ],
      "formats": ["cdxml"],
      "features": [
        "object-tag",
        "enhanced-stereo",
        "query",
        "bracket",
        "symbol",
        "multi-attachment",
        "hydrogen-marker"
      ],
      "regressionCases": ["0030", "0031", "0061", "0062", "0276", "0277", "0278"]
    },
    {
      "name": "hashed-wedge-rendering",
      "pathSubstrings": [
        "crates/chemsema-engine/src/render/bond_metrics.rs",
        "crates/chemsema-engine/src/render_bonds.rs"
      ],
      "features": ["hashed-wedge"],
      "regressionCases": ["0032", "0049", "0059", "0060", "0067", "0069", "0070", "0251", "0409"]
    },
    {
      "name": "render-core",
      "pathEquals": ["crates/chemsema-engine/src/render.rs"],
      "features": ["bond", "text", "graphics"],
      "regressionCases": ["0032", "0049", "0061", "0062"]
    },
    {
      "name": "visual-gate-definition",
      "pathSubstrings": [
        "scripts/public-cdxml-visual-gate.mjs",
        "scripts/render-public-cdxml-visual-review.mjs",
        "scripts/public-cdxml-impact.mjs",
        "scripts/plan-public-cdxml-affected-gate.mjs",
        "benchmarks/public-cdxml/visual-impact-map.json"
      ],
      "full": true
    }
  ],
  "ignoredPathPrefixes": [
    "docs/",
    "crates/chemsema-engine/tests/"
  ],
  "productionPathPrefixes": [
    "crates/chemsema-engine/src/",
    "scripts/"
  ],
  "unknownProductionChange": "full"
}
